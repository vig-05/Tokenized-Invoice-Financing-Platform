# ── Wallet ────────────────────────────────────────────────────────────────────
# Export from MetaMask → Account Details → Export Private Key
# Use a dedicated test wallet — never a wallet with real funds
DEPLOYER_PRIVATE_KEY=0xYOUR_64_CHAR_HEX_PRIVATE_KEY

# ── Polygon Amoy RPC ──────────────────────────────────────────────────────────
# Public endpoint (fine for deploys, rate-limited for heavy use)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# Alchemy alternative (more reliable): https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
# Infura alternative:                  https://polygon-amoy.infura.io/v3/YOUR_KEY

# ── Polygonscan (optional — only needed for `hardhat verify`) ─────────────────
# Get a free key at: https://amoy.polygonscan.com → sign in → API Keys
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Polygon Mainnet RPC (production — not used in hackathon) ──────────────────
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Contract addresses (filled in after deploy) ───────────────────────────────
TOKEN_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=   # Pre-generate before demo; valid 1 trading day

# ── Grok (xAI) ────────────────────────────────────────────────────────────────
GROK_API_KEY=

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET=
